  async function performSearch(query, mode) {
    if (!query) { resultsDiv.innerHTML = '<div class="info-message">🔍 Enter a query above</div>'; return; }
    loader.style.display = 'block';
    resultsDiv.innerHTML = '';
    overviewDiv.classList.remove('visible');
    bestLinkDiv.classList.remove('visible');

    try {
      let html = '', overview = '', best = null;
      switch (mode) {
        case 'web':
          html = await webSearch(query);
          const webData = await fetchWebSearch(query);
          if (webData.best) best = webData.best;
          if (webData.overview) overview = webData.overview;
          break;
        case 'image': html = await imageSearch(query); break;
        case 'movie': html = await movieSearch(query); break;
        case 'finance': html = await financeSearch(query); break;
        case 'cosmic': html = await cosmicSearch(query); break;
        case 'countIt': html = await countItSearch(query); break;
        case 'enkomos': html = await enkomosSearch(query); break;
        case 'marketTrends': html = await marketTrendsSearch(query); break;
        case 'flowerOracle': html = await flowerOracleSearch(query); break;
        case 'wisdom': html = await wisdomSearch(query); break;
        case 'bazar': html = await bazarSearch(query); break;
        case 'csfs': html = await csfsSearch(query); break;
        case 'flowers': html = await flowersSearch(query); break;
        case 'enigma': html = await enigmaSearch(query); break;
        default: html = await webSearch(query);
      }
      if (overview) { overviewText.textContent = overview; overviewDiv.classList.add('visible'); }
      if (best) { bestLinkUrl.href = best.url; bestLinkUrl.textContent = best.title || best.url; bestLinkDisplayUrl.textContent = best.url; bestLinkSnippet.textContent = best.snippet || ''; bestLinkDiv.classList.add('visible'); }
      resultsDiv.innerHTML = html || '<div class="info-message">No results found.</div>';
    } catch (e) {
      resultsDiv.innerHTML = `<div class="info-message error">⚠️ Error: ${e.message}</div>`;
    } finally { loader.style.display = 'none'; }
  }

  async function fetchWebSearch(query) {
    try {
      const url = `https://en.wikipedia.org/api/rest_v1/page/summary/${encodeURIComponent(query)}`;
      const res = await fetch(url);
      if (!res.ok) throw new Error('Wikipedia API failed');
      const data = await res.json();
      if (data.title && data.extract) {
        return { best: { url: `https://en.wikipedia.org/wiki/${encodeURIComponent(data.title.replace(/ /g,'_'))}`, title: data.title, snippet: data.extract.substring(0, 200) + '...' }, overview: data.extract.substring(0, 300) + '...' };
      }
      return { best: null, overview: null };
    } catch (e) { return { best: null, overview: null }; }
  }

  async function webSearch(query) {
    const data = await fetchWebSearch(query);
    if (data.best) {
      return `<div class="result-card"><h3><a href="${data.best.url}" target="_blank" rel="noopener">${data.best.title}</a></h3><div class="url">${data.best.url}</div><div class="snippet">${data.best.snippet}</div></div>`;
    }
    return `<div class="info-message">No web results found for "${query}"</div>`;
  }

  async function imageSearch(query) {
    const url = `https://api.pexels.com/v1/search?query=${encodeURIComponent(query)}&per_page=12`;
    const res = await fetch(url, { headers: { Authorization: PEXELS_KEY } });
    if (!res.ok) throw new Error('Pexels API error');
    const data = await res.json();
    if (!data.photos || data.photos.length === 0) return `<div class="info-message">No images found for "${query}"</div>`;
    return data.photos.map(photo => `
      <div class="image-card">
        <img src="${photo.src.medium}" alt="${photo.alt || query}" loading="lazy">
        <div class="info">
          <h4><a href="${photo.url}" target="_blank" rel="noopener">${photo.alt || query}</a></h4>
          <div class="photographer">📷 <a href="${photo.photographer_url}" target="_blank" rel="noopener">${photo.photographer}</a></div>
        </div>
      </div>
    `).join('');
  }

  async function movieSearch(query) {
    const url = `https://www.omdbapi.com/?s=${encodeURIComponent(query)}&apikey=${OMDb_KEY}`;
    const res = await fetch(url);
    if (!res.ok) throw new Error('OMDb API error');
    const data = await res.json();
    if (data.Response === 'False') return `<div class="info-message">No movies found for "${query}"</div>`;
    return data.Search.slice(0, 10).map(movie => `
      <div class="result-card" style="display:flex;gap:16px;align-items:flex-start;">
        ${movie.Poster && movie.Poster !== 'N/A' ? `<img src="${movie.Poster}" alt="${movie.Title}" class="poster-img">` : `<div class="poster-placeholder">🎬</div>`}
        <div class="movie-info">
          <h3><a href="https://www.imdb.com/title/${movie.imdbID}/" target="_blank" rel="noopener">${movie.Title}</a></h3>
          <div class="movie-detail">${movie.Year} &bull; ${movie.Type}</div>
          <div class="badge">🎬 ${movie.Type}</div>
        </div>
      </div>
    `).join('');
  }

