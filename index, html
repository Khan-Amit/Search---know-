  <title>Search---know-™</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    /* ============================================================
       LIGHT SILVER THEME
       ============================================================ */
    *{margin:0;padding:0;box-sizing:border-box}
    body{background:#d0d0d0;font-family:-apple-system,'Segoe UI',Roboto,system-ui,sans-serif;display:flex;justify-content:center;align-items:flex-start;min-height:100vh;padding:20px 16px 40px;color:#1a1a1a}
    .container{max-width:960px;width:100%;background:#e0e0e0;border-radius:24px;padding:30px 24px;box-shadow:0 8px 32px rgba(0,0,0,0.08)}

    /* ===== BRAND ===== */
    .brand{text-align:center;margin-bottom:30px}
    .brand .logo{font-size:3.2rem;line-height:1;display:block;margin-bottom:4px}
    .brand h1{font-size:2.2rem;font-weight:300;letter-spacing:2px;color:#1a1a1a;margin-top:2px}
    .brand h1 small{font-size:1rem;font-weight:400;color:#555;letter-spacing:1px}
    .brand .byline{font-size:0.9rem;color:#555;margin-top:4px}
    .brand .byline a{color:#1a1a1a;text-decoration:none;border-bottom:1px dotted #888}
    .brand .byline a:hover{color:#000}
    .brand .mardukh{font-size:0.7rem;color:#888;margin-top:4px;letter-spacing:1px}

    /* ===== VISITOR COUNTER ===== */
    .visitor-counter{background:#f5f5f5;border-radius:16px;padding:16px 20px;margin-bottom:20px;border:1px solid #ddd;display:flex;flex-wrap:wrap;gap:12px;justify-content:center;align-items:center}
    .visitor-counter .stat{display:flex;align-items:center;gap:6px;color:#555;font-size:.85rem}
    .visitor-counter .stat strong{color:#1a1a1a;font-size:1.1rem}
    .visitor-counter .online-dot{display:inline-block;width:8px;height:8px;background:#27ae60;border-radius:50%;animation:pulse 1.5s infinite}
    @keyframes pulse{0%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.8)}100%{opacity:1;transform:scale(1)}}
    .visitor-counter .refresh-btn{background:transparent;border:1px solid #ccc;color:#666;padding:4px 12px;border-radius:20px;font-size:.7rem;cursor:pointer;transition:.2s}
    .visitor-counter .refresh-btn:hover{background:#ddd;color:#000}

    /* ===== SEARCH BAR ===== */
    .search-area{background:#f0f0f0;border-radius:60px;padding:8px 8px 8px 20px;display:flex;align-items:center;gap:8px;border:1px solid #ccc;margin-bottom:12px}
    .search-area input[type="text"]{flex:1;background:transparent;border:none;padding:14px 0;font-size:1.1rem;color:#1a1a1a;outline:none;min-width:0}
    .search-area input::placeholder{color:#888;font-style:italic}
    .search-area button{background:#1a1a1a;border:none;border-radius:40px;padding:12px 28px;font-weight:600;font-size:1rem;color:#fff;cursor:pointer;transition:all .2s}
    .search-area button:hover{background:#333;transform:scale(1.01)}

    /* ===== MODE TOGGLE – DYNAMIC APPS ===== */
    .mode-toggle{display:flex;gap:6px;margin-bottom:18px;justify-content:center;flex-wrap:wrap}
    .mode-toggle button{background:#f0f0f0;border:1px solid #ccc;border-radius:40px;padding:8px 16px;font-size:.75rem;font-weight:500;color:#333;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:6px}
    .mode-toggle button:hover{background:#ddd;color:#000}
    .mode-toggle button.active{background:#1a1a1a;color:#fff;border-color:#1a1a1a;box-shadow:0 0 12px rgba(0,0,0,0.08)}
    .mode-toggle button i{font-size:1rem}

    /* ===== GEO TOGGLE ===== */
    .geo-toggle{display:flex;justify-content:flex-end;gap:12px;margin:0 0 16px;font-size:.9rem}
    .geo-toggle label{display:flex;align-items:center;gap:6px;color:#333;cursor:pointer}
    .geo-toggle input[type="radio"]{accent-color:#1a1a1a;width:16px;height:16px}
    .geo-toggle input[type="radio"]:checked+span{color:#000;font-weight:500}

    /* ===== AI OVERVIEW ===== */
    .ai-overview{background:#f5f5f5;border-left:4px solid #1a1a1a;border-radius:8px;padding:16px 20px;margin-bottom:20px;display:none}
    .ai-overview.visible{display:block}
    .ai-overview .label{font-size:.8rem;text-transform:uppercase;letter-spacing:1px;color:#666;display:flex;align-items:center;gap:8px;margin-bottom:4px}
    .ai-overview .label span{background:#1a1a1a;color:#fff;padding:0 10px;border-radius:12px;font-weight:600;font-size:.7rem}
    .ai-overview .summary{font-size:1rem;line-height:1.5;color:#1a1a1a}

    /* ===== RESULTS ===== */
    #results{margin-top:0}
    .result-card{background:#f5f5f5;border-radius:12px;padding:16px 20px;margin-bottom:12px;border:1px solid #ddd}
    .result-card h3{font-size:1.1rem;font-weight:600;margin-bottom:4px;color:#1a1a1a}
    .result-card .url{font-size:.8rem;color:#555;margin-bottom:4px;word-break:break-all}
    .result-card .snippet{font-size:.95rem;line-height:1.4;color:#1a1a1a}
    .result-card .badge{display:inline-block;background:#ccc;padding:2px 10px;border-radius:20px;font-size:.7rem;font-weight:500;color:#333;margin-top:6px}
    .info-message{text-align:center;color:#666;padding:30px 0;font-style:italic}
    .loader{text-align:center;color:#666;padding:20px 0;display:none}
    .loader .spinner{display:inline-block;width:24px;height:24px;border:3px solid #ccc;border-top:3px solid #1a1a1a;border-radius:50%;animation:spin .8s linear infinite}
    @keyframes spin{to{transform:rotate(360deg)}}

    /* ===== VISITOR LOG ===== */
    .visitor-log{background:#f5f5f5;border-radius:12px;padding:16px 20px;margin-top:16px;border:1px solid #ddd;max-height:200px;overflow-y:auto}
    .visitor-log h3{color:#1a1a1a;font-weight:300;font-size:.9rem;margin-bottom:10px;letter-spacing:1px}
    .visitor-log table{width:100%;font-size:.75rem;border-collapse:collapse}
    .visitor-log th{text-align:left;color:#666;font-weight:500;padding-bottom:6px;border-bottom:1px solid #ccc}
    .visitor-log td{padding:4px 0;color:#333;border-bottom:1px solid #eee}
    .visitor-log .flag{font-size:1rem}
    .visitor-log .ip{color:#666;font-size:.65rem}
    .visitor-log .timestamp{color:#888;font-size:.65rem}
    .visitor-log::-webkit-scrollbar{width:4px}
    .visitor-log::-webkit-scrollbar-thumb{background:#ccc;border-radius:4px}
    .visitor-log::-webkit-scrollbar-track{background:transparent}

    /* ===== PAYMENT METHODS ===== */
    .payment-methods{background:#f5f5f5;border-radius:12px;padding:16px 20px;margin-top:16px;border:1px solid #ddd;display:flex;flex-wrap:wrap;gap:12px;justify-content:center;align-items:center}
    .payment-methods .label{color:#666;font-size:.75rem;margin-right:8px}
    .payment-methods .method{display:flex;align-items:center;gap:4px;background:#fff;padding:6px 14px;border-radius:40px;border:1px solid #ccc;font-size:.75rem;color:#333}
    .payment-methods .method .icon{font-size:1rem}

    /* ===== FOOTER ===== */
    .footer{margin-top:40px;text-align:center;font-size:.75rem;color:#666;border-top:1px solid #ccc;padding-top:20px;letter-spacing:.5px}
    .footer a{color:#555;text-decoration:none}
    .footer a:hover{color:#1a1a1a}
    .footer .open-source{font-size:.65rem;color:#888;margin-top:4px}

    /* ===== ADMIN PANEL ===== */
    .admin-panel{display:none;background:#f5f5f5;border-radius:16px;padding:20px;margin-bottom:20px;border:1px solid #ddd}
    .admin-panel.visible{display:block}
    .admin-panel h3{color:#1a1a1a;font-weight:300;letter-spacing:1px;margin-bottom:12px}
    .admin-panel label{color:#666;font-size:.85rem;display:block;margin:8px 0 4px}
    .admin-panel input,.admin-panel textarea{width:100%;background:#fff;border:1px solid #ccc;border-radius:8px;padding:8px 12px;color:#1a1a1a;font-size:.9rem}
    .admin-panel button{background:#1a1a1a;color:#fff;border:none;border-radius:40px;padding:8px 20px;font-weight:600;margin-top:12px;cursor:pointer}
    .admin-panel button:hover{background:#333}
    .admin-toggle{position:fixed;bottom:20px;right:20px;background:#f5f5f5;border:1px solid #ccc;border-radius:40px;padding:8px 16px;color:#666;font-size:.7rem;cursor:pointer;z-index:999}
    .admin-toggle:hover{background:#ddd;color:#000}

