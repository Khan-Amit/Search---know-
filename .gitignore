# ========================================
# 🛡️ MY-AI .gitignore — Hardened Security
# ========================================

# === OS junk ===
.DS_Store
Thumbs.db
*.tmp
*.bak
*.log
*.cache

# === IDE / Editor files ===
.vscode/
.idea/
*.swp
*.swo
*~
*.user
*.userprefs

# === Compiled binaries ===
*.exe
*.dll
*.so
*.dylib
*.o
*.obj
*.out
*.app

# === Build directories ===
build/
bin/
obj/
dist/
node_modules/

# === Environment & Secrets ===
.env
.env.local
.env.*.local
*.key
*.pem
*.crt
*.p12
secrets/
config.local.js

# === Logs & Temporary Data ===
logs/
*.log
*.cache
*.pid
*.seed
*.pid.lock

# === Python / Backend (if added later) ===
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.venv/

# === C++ / Rust compiled (if you add later) ===
target/
debug/
release/
*.pdb

# === Database files ===
*.db
*.sqlite
*.sqlite3
*.db-journal

# === Cloud / Deployment ===
.terraform/
*.tfstate
*.tfstate.*
.aws/
.gcloud/

# === Personal & Local Testing ===
test/
temp/
scratch/
playground/

# === Backup & Archive ===
*.zip
*.tar.gz
*.rar
*.7z
*.bak
*.old

# === GitHub specific ===
*.sublime-project
*.sublime-workspace
.vagrant/
